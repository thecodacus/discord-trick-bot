# Discord bot credentials -- create at https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Restrict the bot to a single guild (server) and channel for the game.
DISCORD_GUILD_ID=123456789012345678
DISCORD_CHANNEL_ID=123456789012345678

# llama-server endpoint (running on homelab)
LLAMA_BASE_URL=http://100.120.130.50:8080
LLAMA_MODEL=Qwen_Qwen3.6-35B-A3B-Q4_K_M  # informational; llama.cpp ignores model name

# Level configuration. Each level has its own secret + role.
# Format: LEVEL_<n>_SECRET, LEVEL_<n>_ROLE_ID, LEVEL_<n>_SYSTEM_PROMPT_FILE
LEVEL_1_SECRET=BANANA
LEVEL_1_ROLE_ID=123456789012345678
LEVEL_1_SYSTEM_PROMPT_FILE=prompts/level_1.txt

LEVEL_2_SECRET=PINEAPPLE
LEVEL_2_ROLE_ID=123456789012345678
LEVEL_2_SYSTEM_PROMPT_FILE=prompts/level_2.txt
